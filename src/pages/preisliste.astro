---

<Layout title="Preisliste – Kosmetik Atelier Laura">
  <main class="max-w-3xl mx-auto px-6 pt-8 pb-16">

    <p class="text-center text-sm text-gray-400 font-serif mb-12 tracking-wide">
      Alle Preise inkl. MwSt. · Änderungen vorbehalten
    </p>

    <div class="flex flex-col gap-12">
      {categories.map((cat) => (
        <section>
          <h2 class="font-serif text-xl text-custom-green tracking-wide mb-4 pb-2 border-b border-gray-200">
            {cat.title}
          </h2>
          {cat.description && (
            <p class="text-sm text-gray-400 mb-4">{cat.description}</p>
          )}

          <ul class="flex flex-col divide-y divide-gray-100">
            {cat.items.map((item) => (
              <li class="py-3">
                <!-- Name + Preis -->
                <div class="flex justify-between items-baseline gap-4">
                  {item.name === "Zusätze" ? (
                    <span class="text-gray-700 font-serif text-md font-semibold">{item.name}</span>
                  ) : (
                    <span class="text-gray-700 font-serif text-sm">{item.name}</span>
                  )}
                  <span class="text-custom-green font-semibold text-sm whitespace-nowrap">{item.price}</span>
                </div>

                <!-- Beschreibung -->
                {item.description && (
                  <p class="text-xs text-gray-400 mt-0.5 leading-relaxed">{item.description}</p>
                )}

                <!-- Extras -->
                {item.extras && item.extras.length > 0 && (
                  <ul class="mt-1.5 flex flex-col gap-0.5">
                    {item.extras.map((e) => (
                      <li class="flex justify-between text-xs text-gray-500 italic">
                        <span>{e.label}</span>
                        <span class="whitespace-nowrap">{e.price}</span>
                      </li>
                    ))}
                  </ul>
                )}

                <!-- Kurspakete -->
                {item.packages && item.packages.length > 0 && (
                  <ul class="mt-2 flex flex-col gap-0.5 bg-gray-50 rounded px-3 py-2">
                    {item.packages.map((p) => (
                      <li class="flex justify-between text-xs text-gray-500">
                        <span>{p.label}</span>
                        <span class="text-custom-green whitespace-nowrap font-medium">{p.price}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </main>
</Layout>