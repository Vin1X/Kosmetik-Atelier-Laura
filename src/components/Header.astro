---
import { Image } from "astro:assets";
import logo_signed from "../assets/logo_signed.svg";

const { pathname } = Astro.url;
const current = pathname.replace(/^\/|\/$/g, "");
const isActive = (path: string) => current === path.replace(/^\/|\/$/g, "");
---

<div class="py-10">
    <div class="flex justify-center pb-10">
        <a href="/" aria-label="Zur Startseite"
            ><Image
                src={logo_signed}
                alt="Kosmetik Atelier Laura Logo"
                inferSize={true}
                width={350}
            /></a
        >
    </div>

    <!-- Hamburger Menu for mobile -->
    <div class="flex justify-center md:hidden">
        <button
            id="menu-toggle"
            aria-controls="main-nav"
            aria-expanded="false"
            aria-label="Menü öffnen"
            class="p-2 text-gray-600 hover:text-custom-green transition-colors duration-200"
        >
            <svg
                id="icon-open"
                xmlns="http://www.w3.org/2000/svg"
                class="w-7 h-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
                id="icon-close"
                xmlns="http://www.w3.org/2000/svg"
                class="w-7 h-7 hidden"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>

    <nav
        id="main-nav"
        aria-label="Navigation"
        class="justify-center hidden md:flex"
    >
        <ul
            class="flex flex-col md:flex-row items-center gap-4 md:gap-6 p-3 tracking-wide"
        >
            <li>
                <a
                    href="/preisliste"
                    class={`font-sans font-semibold tracking-wide text-lg transition-colors duration-200 ${isActive("preisliste") ? "text-custom-green font-bold" : "text-gray-600 hover:text-custom-light-green"}`}
                    aria-current={isActive("preisliste") ? "page" : undefined}
                >
                    Preisliste
                </a>
            </li>
            <li>
                <a
                    href="/kontakt"
                    class={`font-sans font-semibold tracking-wide text-lg transition-colors duration-200 ${isActive("kontakt") ? "text-custom-green font-bold" : "text-gray-600 hover:text-custom-light-green"}`}
                    aria-current={isActive("kontakt") ? "page" : undefined}
                >
                    Kontakt
                </a>
            </li>
        </ul>
    </nav>
</div>

<script>
    const toggle = document.getElementById("menu-toggle");
    const nav = document.getElementById("main-nav");
    const iconOpen = document.getElementById("icon-open");
    const iconClose = document.getElementById("icon-close");

    toggle?.addEventListener("click", () => {
        const isOpen = nav?.classList.toggle("flex");
        nav?.classList.toggle("hidden", !isOpen);

        toggle.setAttribute("aria-expanded", String(isOpen));
        toggle.setAttribute(
            "aria-label",
            isOpen ? "Menü schließen" : "Menü öffnen",
        );

        iconOpen?.classList.toggle("hidden", !!isOpen);
        iconClose?.classList.toggle("hidden", !isOpen);
    });
</script>
