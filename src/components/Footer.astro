---
const currentYear = new Date().getFullYear();
---

<footer
    class="mt-auto border-t border-gray-200 py-10 px-6 text-gray-500 font-serif"
>
    <div
        class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 text-center md:text-left"
    >
        <!-- Navigation -->
        <div>
            <p class="text-custom-green font-bold font-sans tracking-wide">
                Navigation
            </p>
            <hr class="mb-2" />
            <ul class="flex flex-col gap-1 text-sm">
                <li>
                    <a
                        href="/"
                        class="hover:text-custom-light-green hover:underline transition-colors duration-200"
                        >Startseite</a
                    >
                </li>
                <li>
                    <a
                        href="/preisliste"
                        class="hover:text-custom-light-green hover:underline transition-colors duration-200"
                        >Preisliste</a
                    >
                </li>
                <li>
                    <a
                        href="/kontakt"
                        class="hover:text-custom-light-green hover:underline transition-colors duration-200"
                        >Kontakt</a
                    >
                </li>
            </ul>
        </div>

        <!-- Info -->
        <div>
            <p class="text-custom-green font-bold font-sans tracking-wide">
                Öffnungszeiten
            </p>
            <hr class="mb-2" />
            <ul class="text-sm leading-relaxed">
                <li class="flex justify-center md:justify-start gap-4">
                    <span>Mo – Fr</span><span>09:00 – 17:00</span>
                </li>
                <li class="flex justify-center md:justify-start gap-4">
                    <span>Sa & So</span><span>Geschlossen</span>
                </li>
            </ul>
            <p class="text-sm mt-3">
                <a
                    href="tel:+493723560"
                    class="hover:text-custom-light-green hover:underline transition-colors duration-200"
                    >030/372 35 60</a
                >
            </p>
        </div>
    </div>

    <!-- Bottom Bar -->
    <div
        class="max-w-4xl mx-auto mt-8 pt-4 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center gap-2 text-xs text-gray-400"
    >
        <p>© {currentYear} Kosmetik Atelier Laura. Alle Rechte vorbehalten.</p>
        <div class="flex gap-4">
            <a
                href="/impressum"
                class="hover:text-custom-light-green hover:underline transition-colors duration-200"
                >Impressum</a
            >
            <a
                href="/datenschutz"
                class="hover:text-custom-light-green hover:underline transition-colors duration-200"
                >Datenschutz</a
            >
        </div>
    </div>
</footer>
